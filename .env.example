# ════════════════════════════════════════════════════════════════
#  CodeSage AI — Frontend Environment Variables
#  Copy to .env and fill in your values.
# ════════════════════════════════════════════════════════════════

# ── Backend API ──────────────────────────────────────────────────
# URL of the running Express server
VITE_API_URL=http://localhost:3001

# ── Supabase (frontend anon key — safe to expose) ────────────────
# Project URL:  Supabase Dashboard → Settings → API → Project URL
# Anon key:     Supabase Dashboard → Settings → API → anon (public)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
