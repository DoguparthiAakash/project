# ════════════════════════════════════════════════════════════════
#  CodeSage AI — Backend Environment Variables
#  Copy to .env and fill in your values.
# ════════════════════════════════════════════════════════════════

# ── Supabase (REQUIRED for GitHub auth + data persistence) ──────
# Project URL:       Supabase Dashboard → Settings → API → Project URL
# Service Role Key:  Supabase Dashboard → Settings → API → service_role (secret!)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── JWT (REQUIRED) ───────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-64-char-random-hex-string

# ── GitHub OAuth App (REQUIRED for Connect GitHub) ──────────────
# Create at: https://github.com/settings/developers → OAuth Apps → New
#
# Homepage URL:              http://localhost:5173  (or your frontend URL)
# Authorization callback URL: http://localhost:3001/auth/github/callback
#
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# ── AI Providers ─────────────────────────────────────────────────
# Add the key for whichever provider you want as server-side fallback.
# Users can also supply their own keys via the Settings dialog.

# Groq (recommended default) — https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini — https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude — https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# xAI Grok — https://console.x.ai
# XAI_API_KEY=your_xai_api_key_here

# ── Server ───────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Public URL of this backend (used to build OAuth callback URL)
SERVER_URL=http://localhost:3001

# Frontend origin — allowed by CORS + OAuth redirect destination
CLIENT_URL=http://localhost:5173
